# Database (Neon EU — Frankfurt or Ireland)
DATABASE_URL="postgresql://user:pass@host.neon.tech/db?sslmode=require"

# Encryption (32 bytes base64-encoded; generate with: openssl rand -base64 32)
ENCRYPTION_KEY="REPLACE_WITH_OUTPUT_OF_openssl_rand_-base64_32"

# Better Auth (generate secret with: openssl rand -hex 32)
BETTER_AUTH_SECRET="REPLACE_WITH_OUTPUT_OF_openssl_rand_-hex_32"
BETTER_AUTH_URL="http://localhost:3000"

# Owner bootstrap (used by scripts/create-owner.ts)
OWNER_EMAIL=""
OWNER_PASSWORD=""

# Node env (Vercel sets this automatically in production)
NODE_ENV="development"
